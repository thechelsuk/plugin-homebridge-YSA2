{
	"name": "homebridge-ysa2",
	"version": "2.0.6-beta.3",
	"description": "Homebridge plugin for the Yale Sync Alarm",
	"main": "./dist/index.js",
	"types": "./dist/index.d.ts",
	"files": [
		"/dist/**/*",
		".tsconfig.json",
		"README.md",
		"LICENSE"
	],
	"scripts": {
		"test": "echo \"Error: no test specified\" && exit 1",
		"build": "node_modules/typescript/bin/tsc",
		"format": "prettier --write \"src/**/*.ts\" \"src/**/*.js\"",
		"prepare": "npm run build"
	},
	"repository": {
		"type": "git",
		"url": "git+https://github.com/thechelsuk/homebridge-YSA2-plugin.git"
	},
	"keywords": [
		"homebridge",
		"homebridge-plugin",
		"yale",
		"alarm",
		"typescript"
	],
	"author": "thechelsuk",
	"license": "MIT",
	"bugs": {
		"url": "https://github.com/thechelsuk/homebridge-YSA2-plugin/issues"
	},
	"homepage": "https://github.com/thechelsuk/homebridge-YSA2-plugin#readme",
	"engines": {
		"homebridge": "^1.6.0 || ^2.0.0",
		"node": ">=16.19.1"
	},
	"dependencies": {
		"node-fetch": "^2.6.7",
		"type-safe-json-decoder": "0.2.0"
	},
	"devDependencies": {
		"hap-nodejs": "^0.14.3",
		"homebridge": "^1.11.4",
		"prettier": "1.19.1",
		"ts-node": "^10.9.2",
		"typescript": "^4.9.5"
	}
}
