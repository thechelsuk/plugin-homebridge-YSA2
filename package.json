{
	"name": "@thechelsuk/homebridge-yalesyncalarm-2",
	"version": "2.0.2",
	"description": "Homebridge plugin for the Yale Sync Alarm",
	"main": "./dist/YaleSyncPlatform.js",
	"types": "./dist/YaleSyncPlatform.d.ts",
	"files": [
		"/dist/**/*",
		".tsconfig.json",
		"README.md",
		"LICENSE"
	],
	"scripts": {
		"test": "echo \"Error: no test specified\" && exit 1",
		"build": "node_modules/typescript/bin/tsc",
		"format": "prettier --write \"src/**/*.ts\" \"src/**/*.js\"",
		"prepare": "npm run build"
	},
	"repository": {
		"type": "git",
		"url": "git+https://github.com/thechelsuk/homebridge-yalesyncalarm-2.git"
	},
	"keywords": [
		"homebridge",
		"homebridge-plugin",
		"yale",
		"alarm",
		"typescript"
	],
	"author": "thechelsuk",
	"license": "MIT",
	"bugs": {
		"url": "https://github.com/thechelsuk/homebridge-yalesyncalarm-2/issues"
	},
	"homepage": "https://github.com/thechelsuk/homebridge-yalesyncalarm-2#readme",
	"engines": {
		"homebridge": "^1.6.0 || ^2.0.0",
		"node": ">=16.19.1"
	},
	"dependencies": {
		"type-safe-json-decoder": "0.2.0",
		"yalesyncalarm": "2.0.4"
	},
	"devDependencies": {
		"prettier": "1.19.1",
		"typescript": "^4.9.5",
		"hap-nodejs": "^0.14.3"
	}
}